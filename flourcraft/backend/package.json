{
  "name": "flourcraft-backend",
  "version": "1.0.0",
  "description": "FlourCraft - Complete Flour Mill Management System API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build step required for Node.js'",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "setup": "node setup-analytics.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "cache:clear": "node scripts/clear-cache.js",
    "analytics:refresh": "node scripts/refresh-analytics.js",
    "health": "curl http://localhost:5000/health",
    "logs": "tail -f logs/app.log",
    "deploy:railway": "railway deploy",
    "deploy:render": "echo 'Deploy to Render via Git push'",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "flour-mill",
    "management-system",
    "delivery-tracking",
    "inventory-management",
    "real-time-analytics",
    "firebase",
    "postgresql",
    "redis",
    "express",
    "nodejs"
  ],
  "author": "FlourCraft Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/flourcraft-backend.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/flourcraft-backend/issues"
  },
  "homepage": "https://github.com/your-username/flourcraft-backend#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "firebase-admin": "^12.0.0",
    "redis": "^4.6.12",
    "bull": "^4.12.2",
    "cron": "^3.1.6",
    "nodemailer": "^6.9.8",
    "twilio": "^4.19.3",
    "axios": "^1.6.5",
    "uuid": "^9.0.1",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.44",
    "lodash": "^4.17.21",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.3",
    "ws": "^8.16.0",
    "socket.io": "^4.7.4",
    "geolib": "^3.3.4",
    "node-geocoder": "^4.2.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "express-winston": "^4.2.0",
    "@sentry/node": "^7.99.0",
    "@sentry/profiling-node": "^1.3.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "prettier": "^3.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prisma": "^5.7.1",
    "@types/jest": "^29.5.11",
    "cross-env": "^7.0.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "node prisma/seed.js"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": ["<rootDir>/src", "<rootDir>/tests"],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/tests/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"]
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  },
  "nodemonConfig": {
    "ignore": [
      "node_modules/",
      "logs/",
      "uploads/",
      "coverage/",
      "*.test.js"
    ],
    "env": {
      "NODE_ENV": "development"
    },
    "ext": "js,json"
  },
  "eslintConfig": {
    "extends": [
      "airbnb-base",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module"
    },
    "rules": {
      "prettier/prettier": "error",
      "no-console": "off",
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "no-underscore-dangle": "off",
      "consistent-return": "off",
      "no-param-reassign": ["error", { "props": false }]
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false
  }
}