# ===========================================
# FlourCraft Backend Environment Configuration
# ===========================================

# Application Settings
NODE_ENV=production
PORT=5000
APP_NAME=FlourCraft
APP_VERSION=1.0.0
API_BASE_URL=https://your-backend-domain.railway.app

# ===========================================
# Database Configuration
# ===========================================

# PostgreSQL Database (Neon/Supabase)
DATABASE_URL=postgresql://username:password@hostname:5432/database_name
# Example for Neon: postgresql://username:password@ep-xyz-123.us-east-1.aws.neon.tech/flourcraft
# Example for Supabase: postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres

# Database Connection Pool
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=30000

# ===========================================
# Redis Configuration (Caching)
# ===========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
# For Railway Redis: redis://default:password@hostname:port
REDIS_URL=redis://default:password@hostname:port

# ===========================================
# Firebase Configuration
# ===========================================

# Firebase Project Settings
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-abc123@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=123456789012345678901
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-abc123%40your-project.iam.gserviceaccount.com

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Web Config (for frontend)
FIREBASE_API_KEY=AIzaSyAbc123DefGhiJklMnoPqrStuVwxYz
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef123456789

# ===========================================
# Authentication & Security
# ===========================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_REFRESH_SECRET=your-refresh-token-secret-key
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=12

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=https://your-frontend-domain.vercel.app,https://your-custom-domain.com
CORS_CREDENTIALS=true

# ===========================================
# Payment Configuration
# ===========================================

# UPI Payment Integration
UPI_PAYMENT_GATEWAY=your-upi-gateway
UPI_MERCHANT_ID=your-merchant-id
UPI_MERCHANT_KEY=your-merchant-key

# UPI Deeplink Templates
UPI_DEEPLINK_GPAY=tez://upi/pay?pa={VPA}&pn={MERCHANT_NAME}&am={AMOUNT}&cu=INR&tn={TRANSACTION_NOTE}
UPI_DEEPLINK_PHONEPE=phonepe://pay?pa={VPA}&pn={MERCHANT_NAME}&am={AMOUNT}&cu=INR&tn={TRANSACTION_NOTE}
UPI_DEEPLINK_PAYTM=paytmmp://pay?pa={VPA}&pn={MERCHANT_NAME}&am={AMOUNT}&cu=INR&tn={TRANSACTION_NOTE}
UPI_DEEPLINK_BHIM=bhim://pay?pa={VPA}&pn={MERCHANT_NAME}&am={AMOUNT}&cu=INR&tn={TRANSACTION_NOTE}

# Payment Webhook Configuration
PAYMENT_WEBHOOK_SECRET=your-payment-webhook-secret
PAYMENT_SUCCESS_URL=https://your-frontend-domain.vercel.app/payment/success
PAYMENT_FAILURE_URL=https://your-frontend-domain.vercel.app/payment/failure

# ===========================================
# Google Maps Integration
# ===========================================

GOOGLE_MAPS_API_KEY=AIzaSyAbc123DefGhiJklMnoPqrStuVwxYz
GOOGLE_MAPS_PRIVATE_KEY=your-google-maps-private-key

# Google Maps Services
GOOGLE_GEOCODING_API_KEY=AIzaSyAbc123DefGhiJklMnoPqrStuVwxYz
GOOGLE_DIRECTIONS_API_KEY=AIzaSyAbc123DefGhiJklMnoPqrStuVwxYz

# ===========================================
# Email Configuration
# ===========================================

# SMTP Configuration (e.g., SendGrid, Mailgun)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@flourcraft.com
EMAIL_FROM_NAME=FlourCraft

# Email Templates
EMAIL_VERIFICATION_TEMPLATE=d-abc123def456ghi789jkl
PASSWORD_RESET_TEMPLATE=d-def456ghi789jkl012mno
ORDER_CONFIRMATION_TEMPLATE=d-ghi789jkl012mno345pqr

# ===========================================
# SMS Configuration
# ===========================================

# SMS Provider (e.g., Twilio, AWS SNS)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACabc123def456ghi789jkl012mno345pqr
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SMS Templates
SMS_OTP_TEMPLATE=Your FlourCraft OTP is: {OTP}. Valid for 10 minutes.
SMS_ORDER_UPDATE_TEMPLATE=Your order {ORDER_ID} status: {STATUS}. Track: {URL}

# ===========================================
# File Upload Configuration
# ===========================================

# File Storage (Firebase Storage)
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
UPLOAD_PATH=/uploads

# Image Processing
IMAGE_QUALITY=80
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080

# ===========================================
# Logging Configuration
# ===========================================

LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# External Logging (e.g., Logtail, DataDog)
LOGTAIL_SOURCE_TOKEN=your-logtail-source-token

# ===========================================
# Monitoring & Analytics
# ===========================================

# Application Monitoring
SENTRY_DSN=https://abc123def456ghi789jkl012mno345pqr@o123456.ingest.sentry.io/7890123

# Performance Monitoring
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key
NEW_RELIC_APP_NAME=FlourCraft-Backend

# Analytics
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID

# ===========================================
# Background Jobs Configuration
# ===========================================

# Job Queue Settings
QUEUE_REDIS_URL=redis://default:password@hostname:port
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3

# Cron Job Settings
ENABLE_BACKGROUND_JOBS=true
STOCK_ALERT_CRON=0 */6 * * *
ANALYTICS_REFRESH_CRON=0 2 * * *
CLEANUP_CRON=0 3 * * 0

# ===========================================
# External API Configuration
# ===========================================

# Weather API (for delivery optimization)
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Geolocation API
IPGEOLOCATION_API_KEY=your-ipgeolocation-api-key

# ===========================================
# Development & Testing
# ===========================================

# Development Settings (only for local development)
ENABLE_SWAGGER=false
ENABLE_DEBUG_LOGS=false
MOCK_PAYMENTS=false
MOCK_SMS=false

# Testing Database (for running tests)
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/flourcraft_test

# ===========================================
# Security Headers & HTTPS
# ===========================================

# Security Configuration
HELMET_ENABLED=true
FORCE_HTTPS=true
TRUST_PROXY=true

# Session Configuration
SESSION_SECRET=your-session-secret-key
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict

# ===========================================
# Deployment Specific
# ===========================================

# Railway Deployment
RAILWAY_ENVIRONMENT=production
RAILWAY_PROJECT_ID=your-railway-project-id

# Health Check Configuration
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30000

# Graceful Shutdown
SHUTDOWN_TIMEOUT=30000

# ===========================================
# Feature Flags
# ===========================================

# Feature Toggles
ENABLE_SUBSCRIPTIONS=true
ENABLE_REALTIME_TRACKING=true
ENABLE_ANALYTICS_DASHBOARD=true
ENABLE_NOTIFICATIONS=true
ENABLE_CHAT_SUPPORT=false
ENABLE_INVENTORY_ALERTS=true

# ===========================================
# Business Configuration
# ===========================================

# Default Business Settings
DEFAULT_DELIVERY_RADIUS=50
DEFAULT_PROCESSING_TIME=120
MAX_ORDER_ITEMS=20
MIN_ORDER_AMOUNT=100

# Commission & Pricing
PLATFORM_COMMISSION_RATE=0.05
DELIVERY_BASE_CHARGE=50
DELIVERY_PER_KM_CHARGE=5

# Subscription Settings
SUBSCRIPTION_DISCOUNT_RATE=0.10
SUBSCRIPTION_MIN_FREQUENCY=7

# ===========================================
# Localization
# ===========================================

DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata

# Supported Languages
SUPPORTED_LANGUAGES=en,hi,ta,te,kn

# ===========================================
# Cache Configuration
# ===========================================

# Cache TTL Settings (in seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=1800
CACHE_TTL_LONG=7200
CACHE_TTL_ANALYTICS=600

# Cache Key Prefixes
CACHE_PREFIX_USER=user
CACHE_PREFIX_ORDER=order
CACHE_PREFIX_PRODUCT=product
CACHE_PREFIX_ANALYTICS=analytics